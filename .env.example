SEIGE_TARGET_BACKEND=transformerlens
SEIGE_TARGET_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
SEIGE_TRAIN_WHITEBOX_TOOLS=0
SEIGE_WHITEBOX_TOOLS_DIR=data/whitebox_tools
SEIGE_DRY_RUN=0
SEIGE_SAVE_STEPS=50
SEIGE_START_TARGET_SERVER=0
ENV_CUDA_VISIBLE_DEVICES=
SEIGE_AGENT_MODEL_ID=unsloth/Qwen2.5-0.5B-Instruct-bnb-4bit
# LoRA: default is q_proj+v_proj (efficient). Use SEIGE_LORA_TARGET_MODULES to change, e.g.:
#   q_proj,k_proj,v_proj,o_proj  (full attention)  |  q_proj,v_proj,gate_proj,... (wider)
SEIGE_LORA_R=8
SEIGE_LORA_ALPHA=16
# SEIGE_LORA_TARGET_MODULES=q_proj,v_proj
SEIGE_ENV_URL=http://localhost:8000
SEIGE_DEVICE=auto
SEIGE_TL_DTYPE=float32
SEIGE_TARGET_MAX_TOKENS=48
SEIGE_MAX_NEW_TOKENS=48
# Speed vs quality: num_generations>=2 for GRPO group comparison; 2 is a common fast default
SEIGE_GRPO_NUM_GENERATIONS=2
SEIGE_GRPO_MAX_COMPLETION_LENGTH=128
SEIGE_GRPO_MAX_PROMPT_LENGTH=384
SEIGE_GRPO_PER_DEVICE_BATCH=2
SEIGE_GRPO_GRAD_ACCUM=2
GRPO_MAX_STEPS=32
NUM_EPISODES=40
NUM_CYCLES=2
WANDB_PROJECT=seige
SEIGE_HF_PUSH=0
SEIGE_HF_RESTORE=1
SEIGE_HF_REPO_ID=
